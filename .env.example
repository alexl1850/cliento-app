# Cliento Environment Variables
# Copy this to .env.local for local development
# Add these to Vercel → Settings → Environment Variables for production

# ── Supabase ──────────────────────────────────────────
# Get from: supabase.com → Your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...YOUR_PUBLISHABLE_KEY

# ── Anthropic (Claude API) ────────────────────────────
# Get from: console.anthropic.com → API Keys
VITE_ANTHROPIC_KEY=sk-ant-...YOUR_KEY

# ── Paddle (payments) ─────────────────────────────────
# Get from: paddle.com → Catalog → Products → Your product
VITE_PADDLE_PRICE_ID=pri_01...YOUR_PRICE_ID
VITE_PADDLE_ENV=sandbox   # Change to 'production' when ready to go live

# ── Resend (emails) ───────────────────────────────────
# Get from: resend.com → API Keys
# NOTE: Resend is used server-side — add to a backend/edge function,
# not the frontend (keep API keys out of browser code)
# RESEND_API_KEY=re_...YOUR_KEY
