# Cliento Environment Variables
# Copy this to .env.local for local development
# Add these to Vercel → Settings → Environment Variables for production

# ── Supabase ──────────────────────────────────────────
# Get from: supabase.com → Your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...YOUR_PUBLISHABLE_KEY

# ── Anthropic (Claude API) ────────────────────────────
# Get from: console.anthropic.com → API Keys
VITE_ANTHROPIC_KEY=sk-ant-...YOUR_KEY

# ── Paddle (payments) ─────────────────────────────────
# These are read server-side (api/paddle-checkout.js, api/paddle-webhook.js)
# via process.env — no VITE_ prefix, unlike the vars above. A var saved in
# Vercel under a VITE_-prefixed name will NOT be visible to these as
# PADDLE_..., and checkout will fail (or silently create a malformed
# transaction) without ever reaching Paddle's payment page.
# Get from: paddle.com → Developer Tools → Authentication
PADDLE_API_KEY=pdl_...YOUR_API_KEY
# Get from: paddle.com → Catalog → Products → Your product → Price ID
PADDLE_PRICE_ID=pri_01...YOUR_PRICE_ID
# Get from: paddle.com → Developer Tools → Notifications → your webhook
PADDLE_NOTIFICATION_ID=ntfset_01...YOUR_NOTIFICATION_ID
# The client-side token — safe to expose in browser code by design (unlike
# the vars above). Loads Paddle.js and opens the payment overlay directly
# on the paywall screen (src/DashboardA.jsx's PaywallScreen), so this DOES
# need the VITE_ prefix, unlike the three above it.
# Get from: paddle.com → Developer Tools → Authentication → Client-side tokens
VITE_PADDLE_CLIENT_TOKEN=live_...YOUR_CLIENT_TOKEN

# ── Resend (emails) ───────────────────────────────────
# Get from: resend.com → API Keys
# NOTE: Resend is used server-side — add to a backend/edge function,
# not the frontend (keep API keys out of browser code)
# RESEND_API_KEY=re_...YOUR_KEY
