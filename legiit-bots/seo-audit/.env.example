# Required
ANTHROPIC_API_KEY=

# Optional but recommended -- unauthenticated PageSpeed Insights requests are
# rate-limited hard (roughly 1 request per 100s). Get a free key from Google
# Cloud Console (enable "PageSpeed Insights API") for real usage volume.
PAGESPEED_API_KEY=

# Optional -- defaults to claude-opus-4-8. Cost per audit is trivial either way
# (well under $0.20), so only change this if you want to test a cheaper model.
# AUDIT_MODEL=claude-sonnet-5
